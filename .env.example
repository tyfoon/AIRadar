# ──────────────────────────────────────────────────────────────
# AI-Radar — Environment Configuration
# Copy this file to .env and adjust values for your deployment.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# SQLite database path (inside the container)
AIRADAR_DB_PATH=./data/airadar.db

# Zeek log directory on the host (mounted read-only into containers)
ZEEK_LOG_DIR=/opt/zeek/logs/current

# ── AdGuard Home ──────────────────────────────────────────────
# API URL (port 3000 during first-run wizard, port 80 after setup)
ADGUARD_URL=http://localhost:80
# Credentials (set these during AdGuard Home initial setup wizard)
ADGUARD_USER=admin@yourdomain.com
ADGUARD_PASS=change_me_on_first_setup

# ── Gemini AI Recap (premium feature) ────────────────────────
# Used for per-device AI-powered network activity reports
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── CrowdSec IPS ─────────────────────────────────────────────
CROWDSEC_URL=http://localhost:8080
# Generate with: sudo docker exec crowdsec cscli bouncers add airadar_dashboard
CROWDSEC_API_KEY=paste_your_generated_key_here

# ── Network Bridge ────────────────────────────────────────────
# Physical interfaces for the L2 bridge (space-separated)
# Example: "enp1s0 enp2s0" for two ethernet ports on the N95
BRIDGE_INTERFACES=enp1s0 enp2s0
# Bridge IP address (management access + DNS server)
BRIDGE_IP=192.168.1.7/24
# Default gateway
BRIDGE_GATEWAY=192.168.1.1
# Upstream DNS (used by AdGuard as upstream resolver)
UPSTREAM_DNS=1.1.1.1

# ── Inbound Threat Detection ─────────────────────────────────
# Whitelist of ip:port pairs that legitimately receive external traffic.
# Comma-separated. Connections to these are NOT flagged as inbound threats.
# INBOUND_WHITELIST=192.168.1.38:80,192.168.1.38:443
